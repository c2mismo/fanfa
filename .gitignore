# Entorno virtual
.venv/
venv/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===========================================
# DATOS SENSIBLES Y MEMORIA (FANFA)
# ===========================================

# --- data/ ---
# Mantener estructura de directorios, excluir contenido generado
data/*
!data/.gitkeep
!data/vector_store/.gitkeep
!data/user_configs/.gitkeep
!data/backups/.gitkeep

# Excluir archivos de base de datos y sus locks
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
data/*.sqlite3

# Excluir contenido de subdirectorios (pero permitir .gitkeep)
data/vector_store/*
!data/vector_store/.gitkeep
data/user_configs/*
!data/user_configs/.gitkeep
data/backups/*
!data/backups/.gitkeep

# --- logs/ ---
# Mantener directorio, excluir archivos de log rotativos
logs/*
!logs/.gitkeep
logs/*.log
logs/*.log.*
logs/*.gz
logs/*.zip

# --- Seguridad adicional (por si algún archivo se escapa) ---
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Configuraciones con secrets
.env
*.env
.env*
config.local.yaml
*.key
*.pem

# Archivos grandes de modelos
*.gguf
*.bin

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.save
